{
  "name": "excel-exporter",
  "version": "1.0.0",
  "description": "Excel 配置导出工具 - 将 Excel 表格转换为 FlatBuffers 二进制配置文件",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "export-config": "node dist/index.js --source ../excel-config --output ../../assets/resources/config/roguelike --schema ./schemas --force"
  },
  "dependencies": {
    "xlsx": "^0.18.5",
    "flatbuffers": "^24.3.25",
    "commander": "^12.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
